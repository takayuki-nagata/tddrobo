# Google Gemini API Key (Required for model execution)
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) MLflow Tracking Server URI (Defaults to a local SQLite database in session artifacts)
# MLFLOW_TRACKING_URI=http://localhost:5000

# (Optional) Enable debug output and trace logs for TDDRobo agent execution (Set to 1 to enable)
# TDD_ROBO_DEBUG=0
